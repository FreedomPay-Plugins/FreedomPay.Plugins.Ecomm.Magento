<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="fp_payment_transaction" resource="default" engine="innodb"
           comment="Freedompay/Citi Pay Payment Response">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="int" name="customer_id" padding="10" unsigned="true" nullable="false" comment="Customer ID"/>
        <column xsi:type="varchar" name="transaction_id" nullable="true" length="255" comment="Transaction ID"/>
        <column xsi:type="varchar" name="response_status" nullable="true" comment="response_status"/>
        <column xsi:type="text" name="verification_transaction_response" nullable="true"
                comment="VerificationTransaction Response"/>
        <column xsi:type="text" name="get_transaction_response" nullable="true" comment="GetTransaction Response"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FP_PAYMENT_TRANSACTION_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="fp_payment_transaction" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index xsi:type="index" referenceId="FP_PAYMENT_TRANSACTION_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index xsi:type="index" referenceId="FP_PAYMENT_TRANSACTION_TRANSACTION_ID" indexType="btree">
            <column name="transaction_id"/>
        </index>
        <index xsi:type="index" referenceId="FP_PAYMENT_TRANSACTION_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
    </table>
</schema>
