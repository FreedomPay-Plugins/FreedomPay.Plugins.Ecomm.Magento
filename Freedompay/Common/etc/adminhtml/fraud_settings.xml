<?xml version="1.0"?>
<include xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_include.xsd">
            <group id="fraud_settings" translate="label" type="text" sortOrder="350"
                   showInDefault="0" showInWebsite="0" showInStore="0">
                <label>Fraud Settings</label>
                <field id="fraud_check" translate="label" type="select" sortOrder="360"
                       showInDefault="0" showInWebsite="0">
                    <label>Fraud Check</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="fraud_order" translate="label" type="select" sortOrder="370" showInDefault="0"
                       showInWebsite="0" showInStore="0">
                    <label>Fraud Order</label>
                    <source_model>Freedompay\Common\Model\Adminhtml\Source\FraudOrder</source_model>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="fraud_check">1</field>
                    </depends>
                    <comment>Please ensure to fill in this field if fraud check is enabled</comment>
                </field>
                <field id="fraud_void_threshold" translate="label" type="select" sortOrder="380"
                       showInDefault="0" showInWebsite="0">
                    <label>Fraud VoidThreshold</label>
                    <source_model>Freedompay\Common\Model\Adminhtml\Source\FraudVoidThreshold</source_model>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="fraud_check">1</field>
                    </depends>
                    <comment>Please ensure to fill in this field if fraud check is enabled</comment>
                </field>
            </group>
</include>
