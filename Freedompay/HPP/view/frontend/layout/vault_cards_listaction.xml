<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Freedompay_Common::css/base.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <referenceBlock name="vault.cards.list">
                <block class="Freedompay\HPP\Block\Customer\CardRenderer" name="freedompay.card.renderer"
                       template="Freedompay_HPP::customer_account/credit_card.phtml" cacheable="false"/>
            </referenceBlock>
            <block class="Magento\Framework\View\Element\Template"
                   name="freedompay.hpp.customer.addnewcard"
                   template="Freedompay_HPP::customer_account/addNewCard.phtml"
                   after="-"
            >
                <arguments>
                    <argument name="view_model"
                              xsi:type="object">Freedompay\HPP\ViewModel\Customer\AddNewCard</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
