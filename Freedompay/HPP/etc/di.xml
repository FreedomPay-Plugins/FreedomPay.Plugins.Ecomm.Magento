<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Freedompay\Common\Model\Data\XmlParser" type="Freedompay\HPP\Model\Data\XmlParser" />
    <!-- Freedompay Payment Method Facade Configuration -->
    <virtualType name="FreedompayHPPFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">\Freedompay\HPP\Model\Ui\ConfigProvider::CODE</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">FreedompayBlockInfo</argument>
            <argument name="valueHandlerPool" xsi:type="object">FreedompayHPPValueHandlerPool</argument>
            <argument name="commandPool" xsi:type="object">FreedompayHPPCommandPool</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Info Block Type-->
    <virtualType name="FreedompayBlockInfo" type="Freedompay\Common\Block\Info">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Value Handlers Infrastructure -->
    <virtualType name="FreedompayHPPValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">FreedompayHPPConfigValueHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="FreedompayHPPConfigValueHandler" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Commands Infrastructure -->
    <virtualType name="FreedompayHPPCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="createTransaction" xsi:type="string">FreedompayHPPCreateTransactionCommand</item>
                <item name="createVerificationTransaction"
                      xsi:type="string">FreedompayHPPCreateVerificationTransactionCommand</item>
                <item name="getTransaction" xsi:type="string">FreedompayHPPGetTransactionCommand</item>
                <item name="authorize" xsi:type="string">FreedompayHPPAuthorizeCommand</item>
                <item name="capture" xsi:type="string">FreedompayHPPCaptureCommand</item>
                <item name="cancel" xsi:type="string">FreedompayHPPCancelCommand</item>
                <item name="void" xsi:type="string">FreedompayHPPCancelCommand</item>
                <item name="refund" xsi:type="string">FreedompayHPPRefundCommand</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateTransaction Command -->
    <virtualType name="FreedompayHPPCreateTransactionCommand" type="Freedompay\Common\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder"
                      xsi:type="object">FreedompayHPPCreateTransactionRequest</argument>
            <argument name="transferFactory"
                      xsi:type="object">FreedompayHPPCreateTransactionTransferFactory</argument>
            <argument name="client"
                      xsi:type="object">FreedompayHPPTransactionClient</argument>
            <argument name="handler"
                      xsi:type="object">Freedompay\Common\Gateway\Response\ResponseHandler</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateTransaction Request -->
    <virtualType name="FreedompayHPPCreateTransactionRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="base_request"
                      xsi:type="string">FreedompayHPPBaseRequestDataBuilder</item>
                <item name="request_token"
                      xsi:type="string">Freedompay\HPP\Gateway\Request\RequestTokenDataBuilder</item>
                <item name="checkout"
                      xsi:type="string">FreedompayHPPCheckoutDataBuilder</item>
                <item name="token_value"
                      xsi:type="string">Freedompay\HPP\Gateway\Request\TokenValueDatabuilder</item>
                <item name="fp_private"
                      xsi:type="string">Freedompay\HPP\Gateway\Request\FreedompayPrivateDataBuilder</item>
                <item name="fraud_check"
                      xsi:type="string">FreedompayHPPFraudCheckDataBuilder</item>
                <item name="address"
                      xsi:type="string">FreedompayHPPAddressDataBuilder</item>
                <item name="items"
                      xsi:type="string">FreedompayHPPItemsDataBuilder</item>
                <item name="system_info"
                      xsi:type="string">FreedompayHPPSystemInfoRequestDataBuilder</item>
                <item name="additional_payment_methods"
                      xsi:type="string">FreedompayHPPAdditionalPaymentMethodsDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateTransaction Transfer Factory -->
    <virtualType name="FreedompayHPPCreateTransactionTransferFactory"
                 type="Freedompay\Common\Gateway\Http\FreedomPayTransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::END_POINT_CREATE_TRANSACTION</argument>
            </arguments>
    </virtualType>

    <!-- Freedompay Transaction Client -->
    <virtualType name="FreedompayHPPTransactionClient"
                 type="Freedompay\Common\Gateway\Http\Client\FreedomPayClient">
        <arguments>
            <argument name="logger"
                      xsi:type="object">Freedompay\HPP\Logger\Logger</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Transaction Client with Timeout -->
    <virtualType name="FreedompayHPPTransactionClientWithTimeout"
                 type="Freedompay\Common\Gateway\Http\Client\TimeoutReversalClient">
        <arguments>
            <argument name="logger"
                      xsi:type="object">Freedompay\HPP\Logger\Logger</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay AdditionalPaymentMethodsDataBuilder -->
    <virtualType name="FreedompayHPPAdditionalPaymentMethodsDataBuilder"
                 type="Freedompay\Common\Gateway\Request\AdditionalPaymentMethodsDataBuilder">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateVerificationTransaction Command -->
    <virtualType name="FreedompayHPPCreateVerificationTransactionCommand"
                 type="Freedompay\Common\Gateway\Command\GatewayCommand">
        <arguments>
          <argument name="requestBuilder"
                      xsi:type="object">FreedompayHPPCreateVerificationTransactionRequest</argument>
          <argument name="transferFactory"
                      xsi:type="object">FreedompayHPPCreateVerificationTransactionTransferFactory
          </argument>
          <argument name="client"
                      xsi:type="object">FreedompayHPPCreateVerificationTransactionClient</argument>
          <argument name="validator"
                    xsi:type="object">Freedompay\HPP\Gateway\Validator\CreateVerificationResponseValidator</argument>
          <argument name="handler"
                      xsi:type="object">Freedompay\HPP\Gateway\Response\CreateVerificationResponseHandler</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateVerificationTransaction Request -->
    <virtualType name="FreedompayHPPCreateVerificationTransactionRequest"
                 type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="base_request"
                      xsi:type="string">FreedompayHPPBaseRequestDataBuilder</item>
                <item name="request_token"
                      xsi:type="string">Freedompay\HPP\Gateway\Request\RequestTokenDataBuilder</item>
                <item name="fp_private"
                      xsi:type="string">Freedompay\HPP\Gateway\Request\FreedompayPrivateDataBuilder</item>
                <item name="system_info"
                      xsi:type="string">FreedompayHPPSystemInfoRequestDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateVerificationTransaction Transfer Factory -->
    <virtualType name="FreedompayHPPCreateVerificationTransactionTransferFactory"
                 type="Freedompay\Common\Gateway\Http\FreedomPayTransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="transactionType"
              xsi:type="const">Freedompay\HPP\Helper\Requests::END_POINT_CREATE_VERIFICATION_TRANSACTION</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateVerificationTransaction Client -->
    <virtualType name="FreedompayHPPCreateVerificationTransactionClient"
                 type="Freedompay\Common\Gateway\Http\Client\FreedomPayClient">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="transactionType"
              xsi:type="const">Freedompay\HPP\Helper\Requests::END_POINT_CREATE_VERIFICATION_TRANSACTION</argument>
            <argument name="logger"
                      xsi:type="object">Freedompay\HPP\Logger\Logger</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay GetTransaction Command -->
    <virtualType name="FreedompayHPPGetTransactionCommand" type="Freedompay\Common\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder"
                      xsi:type="object">FreedompayHPPGetTransactionRequest</argument>
            <argument name="transferFactory"
                      xsi:type="object">FreedompayHPPGetTransactionTransferFactory</argument>
            <argument name="client"
                      xsi:type="object">FreedompayHPPTransactionClient</argument>
            <argument name="handler"
                      xsi:type="object">Freedompay\Common\Gateway\Response\TransactionIdHandler</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay GetTransaction Request -->
    <virtualType name="FreedompayHPPGetTransactionRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="transaction_id"
                      xsi:type="string">Freedompay\Common\Gateway\Request\TransactionIDDataBuilder
                </item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay GetTransaction Transfer Factory -->
    <virtualType name="FreedompayHPPGetTransactionTransferFactory"
                 type="Freedompay\Common\Gateway\Http\FreedomPayTransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::END_POINT_GET_TRANSACTION</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Capture Command -->
    <virtualType name="FreedompayHPPCaptureCommand" type="Freedompay\Common\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder"
                      xsi:type="object">FreedompayHPPCaptureRequest</argument>
            <argument name="transferFactory"
                      xsi:type="object">FreedompayHPPCaptureTransferFactory</argument>
            <argument name="client"
                      xsi:type="object">FreedompayHPPTransactionClientWithTimeout</argument>
            <argument name="validator"
                      xsi:type="object">FreedompayHPPCaptureResponseValidator</argument>
            <argument name="handler"
                      xsi:type="object">FreedompayHPPCaptureResponseHandler</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Capture Request -->
    <virtualType name="FreedompayHPPCaptureRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="merchant" xsi:type="string">FreedompayHPPMerchantDataBuilder</item>
                <item name="invoice_data" xsi:type="string">Freedompay\Common\Gateway\Request\CaptureDataBuilder</item>
                <item name="additional_information" xsi:type="string">FreedompayHPPCaptureAdditionalDataBuilder</item>
                <item name="system_info" xsi:type="string">FreedompayHPPXmlSystemInfoRequestDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Capture TransferFactory -->
    <virtualType name="FreedompayHPPCaptureTransferFactory"
                 type="Freedompay\Common\Gateway\Http\FreedomPayBackOfficeTransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="serviceType" xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_CAPTURE</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Capture Response Validator -->
    <virtualType name="FreedompayHPPCaptureResponseValidator"
                 type="Freedompay\Common\Gateway\Validator\XmlResponseValidator">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_CAPTURE</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Capture Response Handler -->
    <virtualType name="FreedompayHPPCaptureResponseHandler"
                 type="Freedompay\Common\Gateway\Response\XmlResponseHandler">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_CAPTURE</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Cancel Command -->
    <virtualType name="FreedompayHPPCancelCommand" type="Freedompay\Common\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder"
                      xsi:type="object">FreedompayHPPCancelRequest</argument>
            <argument name="transferFactory"
                      xsi:type="object">FreedompayHPPCancelTransferFactory</argument>
            <argument name="client"
                      xsi:type="object">FreedompayHPPTransactionClientWithTimeout</argument>
            <argument name="validator"
                      xsi:type="object">FreedompayHPPCancelResponseValidator</argument>
            <argument name="handler"
                      xsi:type="object">FreedompayHPPCancelResponseHandler</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Cancel Request -->
    <virtualType name="FreedompayHPPCancelRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="merchant" xsi:type="string">FreedompayHPPMerchantDataBuilder</item>
                <item name="additional_information" xsi:type="string">FreedompayHPPCancelAdditionalDataBuilder</item>
                <item name="system_info" xsi:type="string">FreedompayHPPXmlSystemInfoRequestDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Cancel TransferFactory -->
    <virtualType name="FreedompayHPPCancelTransferFactory"
                 type="Freedompay\Common\Gateway\Http\FreedomPayBackOfficeTransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="serviceType" xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_VOID</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Cancel Response Validator -->
    <virtualType name="FreedompayHPPCancelResponseValidator"
                 type="Freedompay\Common\Gateway\Validator\XmlResponseValidator">
        <arguments>
            <argument name="transactionType" xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_VOID</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Cancel Response Handler -->
    <virtualType name="FreedompayHPPCancelResponseHandler"
                 type="Freedompay\Common\Gateway\Response\XmlResponseHandler">
        <arguments>
            <argument name="transactionType" xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_VOID</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Refund Command -->
    <virtualType name="FreedompayHPPRefundCommand" type="Freedompay\Common\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder"
                      xsi:type="object">FreedompayHPPRefundRequest</argument>
            <argument name="transferFactory"
                      xsi:type="object">FreedompayHPPRefundTransferFactory</argument>
            <argument name="client"
                      xsi:type="object">FreedompayHPPTransactionClientWithTimeout</argument>
            <argument name="validator"
                      xsi:type="object">FreedompayHPPRefundResponseValidator</argument>
            <argument name="handler"
                      xsi:type="object">FreedompayHPPRefundResponseHandler</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Refund Request -->
    <virtualType name="FreedompayHPPRefundRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="merchant" xsi:type="string">FreedompayHPPMerchantDataBuilder</item>
                <item name="credit_memo"
                      xsi:type="string">Freedompay\Common\Gateway\Request\RefundDataBuilder</item>
                <item name="additional_information" xsi:type="string">FreedompayHPPRefundAdditionalDataBuilder</item>
                <item name="system_info" xsi:type="string">FreedompayHPPXmlSystemInfoRequestDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Refund TransferFactory -->
    <virtualType name="FreedompayHPPRefundTransferFactory"
                 type="Freedompay\Common\Gateway\Http\FreedomPayBackOfficeTransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="serviceType" xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_REFUND</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Refund Response Validator -->
    <virtualType name="FreedompayHPPRefundResponseValidator"
                 type="Freedompay\Common\Gateway\Validator\XmlResponseValidator">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_REFUND</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Refund Response Handler -->
    <virtualType name="FreedompayHPPRefundResponseHandler"
                 type="Freedompay\Common\Gateway\Response\XmlResponseHandler">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_REFUND</argument>
        </arguments>
    </virtualType>

    <!-- Magento Authorize Command -->
    <virtualType name="FreedompayHPPAuthorizeCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder"
                      xsi:type="object">Freedompay\Common\Gateway\Request\TransactionIDDataBuilder</argument>
            <argument name="transferFactory"
                      xsi:type="object">Freedompay\Common\Gateway\Http\MagentoTransactionTransferFactory
            </argument>
            <argument name="client"
                      xsi:type="object">Freedompay\Common\Gateway\Http\Client\MagentoTransactionClient</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Base Request Data Builder -->
    <virtualType name="FreedompayHPPBaseRequestDataBuilder"
                 type="Freedompay\Common\Gateway\Request\BaseRequestDataBuilder">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="requestHelper" xsi:type="object">FreedompayHPPRequestHelper</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Checkout Data Builder -->
    <virtualType name="FreedompayHPPCheckoutDataBuilder"
                 type="Freedompay\Common\Gateway\Request\CheckoutDataBuilder">
        <arguments>
            <argument name="requestHelper" xsi:type="object">FreedompayHPPRequestHelper</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Fraud Check Data Builder -->
    <virtualType name="FreedompayHPPFraudCheckDataBuilder"
                 type="Freedompay\Common\Gateway\Request\FraudCheckServiceDataBuilder">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Merchant  Data Builder -->
    <virtualType name="FreedompayHPPMerchantDataBuilder"
                 type="Freedompay\Common\Gateway\Request\MerchantDataBuilder">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Address Data Builder -->
    <virtualType name="FreedompayHPPAddressDataBuilder"
                 type="Freedompay\Common\Gateway\Request\AddressDataBuilder">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="requestHelper" xsi:type="object">FreedompayHPPRequestHelper</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Items Data Builder -->
    <virtualType name="FreedompayHPPItemsDataBuilder"
                 type="Freedompay\Common\Gateway\Request\ItemsDataBuilder">
        <arguments>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Capture Additional Information Data Builder -->
    <virtualType name="FreedompayHPPCaptureAdditionalDataBuilder"
                 type="Freedompay\Common\Gateway\Request\AdditionalInformationDataBuilder">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_CAPTURE</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Refund Additional Information Data Builder -->
    <virtualType name="FreedompayHPPRefundAdditionalDataBuilder"
                 type="Freedompay\Common\Gateway\Request\AdditionalInformationDataBuilder">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_REFUND</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Cancel Additional Information Data Builder -->
    <virtualType name="FreedompayHPPCancelAdditionalDataBuilder"
                 type="Freedompay\Common\Gateway\Request\AdditionalInformationDataBuilder">
        <arguments>
            <argument name="transactionType"
                      xsi:type="const">Freedompay\Common\Helper\Requests::SERVICE_VOID</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay System Info Builder -->
    <virtualType name="FreedompayHPPSystemInfoRequestDataBuilder"
                 type="Freedompay\Common\Gateway\Request\SystemInfoDataBuilder">
        <arguments>
            <argument name="requestHelper" xsi:type="object">FreedompayHPPRequestHelper</argument>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="moduleName"
                      xsi:type="const">Freedompay\HPP\Gateway\Config\PaymentConfig::MODULE_NAME</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay XML System Info Builder -->
    <virtualType name="FreedompayHPPXmlSystemInfoRequestDataBuilder"
                 type="Freedompay\Common\Gateway\Request\XmlSystemInfoDataBuilder">
        <arguments>
            <argument name="requestHelper" xsi:type="object">FreedompayHPPRequestHelper</argument>
            <argument name="config" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
            <argument name="moduleName"
                      xsi:type="const">Freedompay\HPP\Gateway\Config\PaymentConfig::MODULE_NAME</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay Request Helper -->
    <virtualType name="FreedompayHPPRequestHelper"
                 type="Freedompay\Common\Helper\Requests">
        <arguments>
            <argument name="paymentConfig" xsi:type="object">Freedompay\HPP\Gateway\Config\PaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Freedompay CreateTransaction Service -->
    <type name="Freedompay\HPP\Model\CreateTransaction">
        <arguments>
            <argument name="commandPool" xsi:type="object">FreedompayHPPCommandPool</argument>
        </arguments>
    </type>

    <!-- Freedompay GetTransaction Service -->
    <type name="Freedompay\HPP\Model\GetTransaction">
        <arguments>
            <argument name="commandPool" xsi:type="object">FreedompayHPPCommandPool</argument>
        </arguments>
    </type>

    <!-- Freedompay CreateVerification Service -->
    <type name="Freedompay\HPP\Model\CreateVerification">
        <arguments>
            <argument name="commandPool" xsi:type="object">FreedompayHPPCommandPool</argument>
        </arguments>
    </type>

    <!-- Freedompay Log Handler -->
    <type name="Freedompay\HPP\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">FreedompayHPPLogHandler</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Freedompay\Common\Logger\Handler</item>
            </argument>
        </arguments>
    </type>
</config>
