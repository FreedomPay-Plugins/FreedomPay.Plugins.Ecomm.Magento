<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product.info.form.content">
            <block class="Magento\Framework\View\Element\Template" name="product.info.mil.cart.block"
                   template="Citipay_HPP::payment-estimator/pdp/productPage.phtml" before="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Citipay\HPP\ViewModel\PaymentEstimator\Pdp\CalculationHtml
                    </argument>
                </arguments>
            </block>
        </referenceBlock>
        <referenceBlock name="product.info.form.options">
            <block class="Magento\Framework\View\Element\Template" name="product.info.mil.cart.block.options"
                   template="Citipay_HPP::payment-estimator/pdp/productPage.phtml" before="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Citipay\HPP\ViewModel\PaymentEstimator\Pdp\CalculationHtml
                    </argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
