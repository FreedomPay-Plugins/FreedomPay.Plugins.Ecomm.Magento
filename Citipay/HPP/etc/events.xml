<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="checkout_submit_all_after">
        <observer name="citipay_hpp_submit_all_after" instance="Citipay\HPP\Observer\CheckoutSubmitAllAfter"/>
    </event>
    <event name="payment_method_assign_data_citipay_hpp">
        <observer name="citipay_hpp_data_assign"
                  instance="Citipay\HPP\Observer\DataAssignObserver" />
    </event>
    <event name="sales_model_service_quote_submit_success">
        <observer name="citipay_hpp_quote_submit" instance="Citipay\HPP\Observer\SubmitQuoteObserver" />
    </event>
</config>
