<?xml version="1.0"?>
<config
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="citipay_hpp" translate="label" type="text" sortOrder="10"
                   showInDefault="0" showInWebsite="0" showInStore="0">
                <label>Citi Pay</label>
                <field id="active" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="mode" translate="label" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1">
                    <label>Mode</label>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                    <source_model>Freedompay\Common\Model\Adminhtml\Source\Environment</source_model>
                </field>
                <field id="test_store_id" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="1">
                    <label>Test Store ID</label>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="mode">test</field>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="test_terminal_id" translate="label" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="1">
                    <label>Test Terminal ID</label>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="mode">test</field>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="live_store_id" translate="label" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="1">
                    <label>Live Store ID</label>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="mode">live</field>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="live_terminal_id" translate="label" type="text" sortOrder="80"
                       showInDefault="1" showInWebsite="1">
                    <label>Live Terminal ID</label>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="mode">live</field>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="eskey" translate="label" type="text" sortOrder="90"
                       showInDefault="1" showInWebsite="1">
                    <label>ESKey</label>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="css_id" translate="label" type="text" sortOrder="100"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CSS ID</label>
                    <tooltip>Hosted Payment Page supports customized CSS templates. If you would like to configure
                        a custom style, please contact your Account Manager or our Systems Integrations team for
                        guidance as to which value to enter here that needs to map to the CSS ID
                        which the merchant holds against your Store account
                    </tooltip>
                </field>
                <field id="citipay_type" translate="label" type="select" sortOrder="105"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Citi Pay Type</label>
                    <validate>required-entry</validate>
                    <source_model>Citipay\HPP\Model\Adminhtml\Source\PaymentChannel</source_model>
                    <tooltip>The Transaction Type allowed for MIL is "Auth Only".
                        Sale selected will be automatically overridden
                    </tooltip>
                </field>
                <field id="payment_action" translate="label" type="select" sortOrder="120"
                       showInDefault="1" showInWebsite="1">
                    <label>Transaction Type</label>
                    <validate>required-entry</validate>
                    <source_model>Citipay\HPP\Model\Adminhtml\Source\PaymentAction</source_model>
                    <tooltip>Transaction Type supports both “Auth Only” and “Sale” transaction methods.
                        For business where goods or services are delivered after a delay, payment authorization and
                        capture should be handled separately to comply with card scheme requirements.
                        In such cases, the payment authorization occurs at the time of purchase, and capture should be
                        completed once the goods or services are fulfilled or dispatched.
                        This process is typically managed through order or invoice management systems to ensure
                        compliance and smooth transaction processing.
                    </tooltip>
                </field>
                <field id="show_address" translate="label" type="select" sortOrder="130"
                       showInDefault="1" showInWebsite="1">
                    <label>Show Address</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="address_required" translate="label" type="select" sortOrder="140"
                       showInDefault="1" showInWebsite="1">
                    <label>Address Required</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="allow_intl_address" translate="label" type="select" sortOrder="150"
                       showInDefault="1" showInWebsite="1">
                    <label>Allow Global Address</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="system_name" translate="label" type="text" sortOrder="170"
                       showInDefault="1" showInWebsite="1">
                    <label>System Name</label>
                    <validate>required-entry validate-length maximum-length-50</validate>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="system_version" translate="label" type="text" sortOrder="180"
                       showInDefault="1" showInWebsite="1">
                    <label>System Version</label>
                    <validate>required-entry validate-length maximum-length-50</validate>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="allowspecific" translate="label" type="allowspecific" sortOrder="190" showInDefault="9"
                       showInWebsite="1">
                    <label>Payment From Applicable Countries</label>
                    <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="200" showInDefault="1"
                       showInWebsite="1">
                    <label>Payment From Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="210" showInDefault="1"
                       showInWebsite="1">
                    <label>Sort Order</label>
                    <frontend_class>validate-number</frontend_class>
                </field>
                <field id="mandatory_validation" translate="label" type="select"
                       sortOrder="215" showInDefault="1" showInWebsite="1">
                    <label>Enable mandatory field validation</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Validates the payload and logs missing mandatory FreedomPay fields in the admin</comment>
                </field>
                <field id="debug" translate="label" type="select" sortOrder="220"
                       showInDefault="1" showInWebsite="1">
                    <label>Enable Debug Log</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="download_logs" translate="label" type="label" sortOrder="230" showInDefault="1"
                       showInWebsite="1">
                    <frontend_model>Citipay\HPP\Block\Adminhtml\System\Config\Form\Field\Link\DownloadLogs</frontend_model>
                </field>
                <group id="citipay_payment_estimator" translate="label" type="text" sortOrder="240" showInDefault="1"
                       showInWebsite="1" showInStore="1">
                    <label>Payment Estimator Settings</label>
                    <field id="enabled" translate="label" type="select" sortOrder="250" showInDefault="1"
                           showInWebsite="1" showInStore="1">
                        <label>Citi Pay Payment Estimator Enabled</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <tooltip>The Citi Pay payment method and Payment Estimator functionality should only be enabled
                            if this has been boarded as a payment method.
                        </tooltip>
                    </field>
                    <field id="mode" translate="label" type="select" sortOrder="260"
                           showInDefault="1" showInWebsite="1">
                        <label>Citi Pay Payment Estimator Mode</label>
                        <source_model>Freedompay\Common\Model\Adminhtml\Source\Environment</source_model>
                        <depends>
                            <field id="enabled">1</field>
                        </depends>
                    </field>
                    <field id="test_client_id" translate="label" type="text" sortOrder="280"
                           showInDefault="1" showInWebsite="1">
                        <label>Citi Pay Payment Estimator Test Client ID</label>
                        <validate>required-entry</validate>
                        <depends>
                            <field id="mode">test</field>
                            <field id="enabled">1</field>
                        </depends>
                    </field>
                    <field id="live_client_id" translate="label" type="text" sortOrder="290"
                           showInDefault="1" showInWebsite="1">
                        <label>Citi Pay Payment Estimator Live Client ID</label>
                        <validate>required-entry</validate>
                        <depends>
                            <field id="mode">live</field>
                            <field id="enabled">1</field>
                        </depends>
                    </field>
                    <field id="test_client_secret" translate="label" type="text" sortOrder="300"
                           showInDefault="1" showInWebsite="1">
                        <label>Citi Pay Payment Estimator Test Client Secret</label>
                        <validate>required-entry</validate>
                        <depends>
                            <field id="mode">test</field>
                            <field id="enabled">1</field>
                        </depends>
                    </field>
                    <field id="live_client_secret" translate="label" type="text" sortOrder="310"
                           showInDefault="1" showInWebsite="1">
                        <label>Citi Pay Payment Estimator Live Client Secret</label>
                        <validate>required-entry</validate>
                        <depends>
                            <field id="mode">live</field>
                            <field id="enabled">1</field>
                        </depends>
                    </field>
                    <field id="enable_pdp_messaging" translate="label" type="select" sortOrder="320"
                           showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Citi Pay Payment Estimator Enable PDP messaging</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends>
                            <field id="enabled">1</field>
                        </depends>
                        <comment>If disabled, Citi Pay Payment Estimator messaging will be hidden in PDP
                            (even if Citi Pay Payment Estimator messaging is enabled via
                            'Citi Pay Payment Estimator Enabled' drop down)</comment>
                    </field>
                </group>
            </group>
        </section>
    </system>
</config>
